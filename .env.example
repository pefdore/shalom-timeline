# Configuration Google Sheets (optionnel - fonctionne sans en mode dev)
# Pour activer la connexion Google Sheets:
# 1. Crée un projet Google Cloud
# 2. Active Google Sheets API
# 3. Crée un Service Account et téléverse la clé JSON
# 4. Partage ton Google Sheet avec le service account (email type: xxx@xxx.iam.gserviceaccount.com)

# ID du Google Sheet (trouvé dans l'URL du sheet)
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Credentials du Service Account (JSON complet)
# GOOGLE_SERVICE_ACCOUNT={"type":"service_account",...}